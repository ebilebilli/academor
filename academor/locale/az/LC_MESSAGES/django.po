msgstr "%(count)s mövzu"

msgid "%(topic)s | English conversation | Academor"
msgstr "%(topic)s | İngilis dilində danışıq | Academor"

msgid "Model sentences and questions in English; localized tips and vocabulary glosses."
msgstr ""
"Nümunə cümlələr və suallar ingilis dilindədir; tədris üçün qısa qeydlər və sözlərin izahı isə seçdiyiniz "
"dildə verilir."

msgid "english conversation, speaking practice, esl, %(topic)s"
msgstr "ingilis dilində danışıq, danışıq təcrübəsi, ingilis dili, %(topic)s"

